{
  "manifest_version": 3,
  "name": "Senova",
  "version": "2.17",
  "description": "Radar de mercado para executivos sêniors. Score IA, captura de vagas e sinais com 1 clique.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "alarms", "cookies"],
  "host_permissions": [
    "https://senova-proxy.marcos-mco.workers.dev/*",
    "https://marcos-mco.github.io/*",
    "https://www.linkedin.com/*",
    "https://boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://apply.workable.com/*",
    "https://*.gupy.io/*",
    "https://www.indeed.com/*",
    "https://br.indeed.com/*",
    "https://www.catho.com.br/*",
    "https://www.vagas.com.br/*",
    "https://www.inhire.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/feed/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://apply.workable.com/*",
        "https://*.gupy.io/*",
        "https://www.indeed.com/*",
        "https://br.indeed.com/*",
        "https://www.catho.com.br/*",
        "https://www.vagas.com.br/*",
        "https://www.inhire.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Senova",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
